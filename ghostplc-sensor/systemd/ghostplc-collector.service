[Unit]
Description=GhostPLC event collector
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
User=__GHOSTPLC_USER__
Group=__GHOSTPLC_GROUP__
SupplementaryGroups=docker
WorkingDirectory=__GHOSTPLC_ROOT__
EnvironmentFile=-__GHOSTPLC_ROOT__/.env
ExecStart=__GHOSTPLC_ROOT__/.venv/bin/python __GHOSTPLC_ROOT__/collector/collector.py
