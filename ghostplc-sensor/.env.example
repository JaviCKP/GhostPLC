# Google Cloud e2-* VMs are x86_64, so the public Conpot image works.
CONPOT_IMAGE=honeynet/conpot:latest

# Defaults resolve to ~/ghostplc-sensor/data for the service user.
# Override only if you install the sensor somewhere else.
# GHOSTPLC_DATA_DIR=/home/YOUR_USER/ghostplc-sensor/data
# GHOSTPLC_DB_PATH=/home/YOUR_USER/ghostplc-sensor/data/ghostplc.sqlite3
GHOSTPLC_MAX_EVENTS=5000
GHOSTPLC_EXPORT_EVENTS_JSON=0
GHOSTPLC_API_TOKEN=change-this-to-a-long-random-token

# Optional. Use a MaxMind GeoLite2 City .mmdb file when you add real GeoIP.
# GHOSTPLC_GEOIP_DB=/home/YOUR_USER/ghostplc-sensor/GeoLite2-City.mmdb

# Optional AI analysis. Disabled until explicitly enabled.
GHOSTPLC_AI_ENABLED=0
GHOSTPLC_AI_MODEL=gpt-5-nano
GHOSTPLC_AI_REASONING_EFFORT=minimal
GHOSTPLC_AI_WINDOW_MINUTES=60
GHOSTPLC_AI_EVENT_LIMIT=1000
GHOSTPLC_AI_SAMPLE_EVENT_LIMIT=120
# OPENAI_API_KEY=your_openai_api_key
